      <!-- "How to play" Screen -->
      <AnchorPane fx:id="howToPlayScreen" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="450.0" prefWidth="600.0" style="-fx-background-color: #DDE5F8; -fx-border-color: linear-gradient(from 0% 0% to 100% 100%, #101014, #2A5ACB); -fx-border-width: 10.5;" visible="false">
         <children>

            <!-- "How to Play" Label -->
            <Label alignment="CENTER" contentDisplay="CENTER" layoutX="50.0" layoutY="45.0" prefHeight="49.0" prefWidth="499.0" text="How to Play" textAlignment="CENTER">
               <font>
                  <Font name="Rockwell" size="42.0" />
               </font>
            </Label>

            <!-- "Game Rules" Scroll Pane -->
            <ScrollPane fx:id="scrollPane" layoutX="77.0" layoutY="102.0" prefHeight="288.0" prefWidth="446.0" style="-fx-background-color: transparent;" stylesheets="@scrollPaneStyle.css">
              <content>

                 <!-- AnchorPane with the rules -->
                 <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="717.0" prefWidth="428.0" style="-fx-background-color: transparent;">
                     <children>

                        <!-- Rules -->
                        <VBox alignment="TOP_CENTER" layoutX="8.0" layoutY="5.0" prefHeight="713.0" prefWidth="412.0">
                           <children>

                              <Label prefHeight="18.0" prefWidth="421.0" text="Objective" textAlignment="CENTER">
                                 <font>
                                    <Font name="Rockwell" size="19.0" />
                                 </font>
                              </Label>
                              <Label layoutX="10.0" layoutY="10.0" prefHeight="52.0" prefWidth="412.0" text="The goal of blackjack is to beat the dealer by having a hand value closer to 21 without going over." textAlignment="JUSTIFY" wrapText="true">
                                 <font>
                                    <Font name="Bell MT" size="15.0" />
                                 </font>
                                 <padding>
                                    <Insets bottom="15.0" />
                                 </padding>
                              </Label>
                              <Label layoutX="10.0" layoutY="10.0" prefHeight="18.0" prefWidth="421.0" text="Card Values" textAlignment="CENTER">
                                 <font>
                                    <Font name="Rockwell" size="19.0" />
                                 </font>
                              </Label>
                              <Label layoutX="10.0" layoutY="33.0" prefHeight="9.0" prefWidth="412.0" text="- Number cards (2-10): Face value" textAlignment="JUSTIFY" wrapText="true">
                                 <font>
                                    <Font name="Bell MT" size="15.0" />
                                 </font>
                                 <VBox.margin>
                                    <Insets bottom="2.0" />
                                 </VBox.margin>
                              </Label>
                              <Label layoutX="10.0" layoutY="108.0" prefHeight="9.0" prefWidth="412.0" text="- Face cards (Jack, Queen, King): 10 points each" textAlignment="JUSTIFY" wrapText="true">
                                 <font>
                                    <Font name="Bell MT" size="15.0" />
                                 </font>
                                 <VBox.margin>
                                    <Insets bottom="2.0" />
                                 </VBox.margin>
                              </Label>
                              <Label layoutX="10.0" layoutY="127.0" prefHeight="9.0" prefWidth="412.0" text="- Aces: 1 or 11 points (whichever is more favorable for your hand)" textAlignment="JUSTIFY" wrapText="true">
                                 <font>
                                    <Font name="Bell MT" size="15.0" />
                                 </font>
                                 <padding>
                                    <Insets bottom="15.0" />
                                 </padding>
                                 <VBox.margin>
                                    <Insets bottom="2.0" />
                                 </VBox.margin>
                              </Label>
                              <Label layoutX="10.0" layoutY="85.0" prefHeight="18.0" prefWidth="421.0" text="Basic Gameplay" textAlignment="CENTER">
                                 <font>
                                    <Font name="Rockwell" size="19.0" />
                                 </font>
                              </Label>
                              <Label layoutX="10.0" layoutY="108.0" prefHeight="9.0" prefWidth="412.0" text="1. Place Your Bet: The player places a bet in their betting circle." textAlignment="JUSTIFY" wrapText="true">
                                 <font>
                                    <Font name="Bell MT" size="15.0" />
                                 </font>
                                 <VBox.margin>
                                    <Insets bottom="2.0" />
                                 </VBox.margin>
                              </Label>
                              <Label layoutX="10.0" layoutY="202.0" prefHeight="60.0" prefWidth="412.0" text="2. Deal: The player and the dealer receive two cards. Players’ cards are usually dealt face up, while the dealer has one card face up and one face down." textAlignment="JUSTIFY" wrapText="true">
                                 <font>
                                    <Font name="Bell MT" size="15.0" />
                                 </font>
                                 <VBox.margin>
                                    <Insets bottom="2.0" />
                                 </VBox.margin>
                              </Label>
                              <Label layoutX="10.0" layoutY="220.0" prefHeight="6.0" prefWidth="412.0" text="3. The player decides to:" textAlignment="JUSTIFY" wrapText="true">
                                 <font>
                                    <Font name="Bell MT" size="15.0" />
                                 </font>
                                 <padding>
                                    <Insets bottom="15.0" />
                                 </padding>
                              </Label>
                              <Label layoutX="10.0" layoutY="220.0" prefHeight="2.0" prefWidth="412.0" text="- Hit: Take another card." textAlignment="JUSTIFY" wrapText="true">
                                 <font>
                                    <Font name="Bell MT" size="15.0" />
                                 </font>
                                 <VBox.margin>
                                    <Insets bottom="2.0" />
                                 </VBox.margin>
                              </Label>
                              <Label layoutX="10.0" layoutY="295.0" prefHeight="7.0" prefWidth="412.0" text="- Stand: Keep their current hand." textAlignment="JUSTIFY" wrapText="true">
                                 <font>
                                    <Font name="Bell MT" size="15.0" />
                                 </font>
                                 <VBox.margin>
                                    <Insets bottom="2.0" />
                                 </VBox.margin>
                              </Label>
                              <Label layoutX="10.0" layoutY="338.0" prefHeight="41.0" prefWidth="412.0" text="- Split: If the first two cards are of the same value, split them into two separate hands (requires an additional bet)." textAlignment="JUSTIFY" wrapText="true">
                                 <font>
                                    <Font name="Bell MT" size="15.0" />
                                 </font>
                                 <VBox.margin>
                                    <Insets bottom="2.0" />
                                 </VBox.margin>
                              </Label>
                              <Label layoutX="10.0" layoutY="360.0" prefHeight="42.0" prefWidth="412.0" text="- Dealer’s Turn: The dealer reveals their face-down card and must hit until their hand totals 17 or higher." textAlignment="JUSTIFY" wrapText="true">
                                 <font>
                                    <Font name="Bell MT" size="15.0" />
                                 </font>
                                 <VBox.margin>
                                    <Insets bottom="2.0" />
                                 </VBox.margin>
                              </Label>
                              <Label layoutX="10.0" layoutY="400.0" prefHeight="56.0" prefWidth="412.0" text="- Determine the Winner: Compare the player’s hand to the dealer’s. The closest to 21 without going over wins." textAlignment="JUSTIFY" wrapText="true">
                                 <font>
                                    <Font name="Bell MT" size="15.0" />
                                 </font>
                                 <padding>
                                    <Insets bottom="15.0" />
                                 </padding>
                                 <VBox.margin>
                                    <Insets bottom="2.0" />
                                 </VBox.margin>
                              </Label>
                              <Label layoutX="10.0" layoutY="179.0" prefHeight="18.0" prefWidth="421.0" text="Special Rules" textAlignment="CENTER">
                                 <font>
                                    <Font name="Rockwell" size="19.0" />
                                 </font>
                              </Label>
                              <Label layoutX="10.0" layoutY="400.0" prefHeight="38.0" prefWidth="412.0" text="- Blackjack: An Ace and a 10-point card on the initial deal. Pays 1.5 times the player's bet." textAlignment="JUSTIFY" wrapText="true">
                                 <font>
                                    <Font name="Bell MT" size="15.0" />
                                 </font>
                                 <VBox.margin>
                                    <Insets bottom="2.0" />
                                 </VBox.margin>
                              </Label>
                              <Label layoutX="10.0" layoutY="508.0" prefHeight="15.0" prefWidth="412.0" text="- Bust: Going over 21. Automatically lose the bet." textAlignment="JUSTIFY" wrapText="true">
                                 <font>
                                    <Font name="Bell MT" size="15.0" />
                                 </font>
                                 <VBox.margin>
                                    <Insets bottom="2.0" />
                                 </VBox.margin>
                              </Label>
                              <Label layoutX="10.0" layoutY="579.0" prefHeight="11.0" prefWidth="412.0" text="- Push: A tie with the dealer. The bet is returned." textAlignment="JUSTIFY" wrapText="true">
                                 <font>
                                    <Font name="Bell MT" size="15.0" />
                                 </font>
                                 <VBox.margin>
                                    <Insets bottom="25.0" />
                                 </VBox.margin>
                              </Label>

                              <!-- "Understood" Button -->
                              <Button alignment="CENTER" mnemonicParsing="false" onMouseClicked="#turnOffTutorial" prefHeight="51.0" prefWidth="140.0" style="-fx-background-color: #BA1512; -fx-border-color: #FFBD00; -fx-background-radius: 50; -fx-border-radius: 50; -fx-border-width: 5; -fx-border-style: dotted;" text="Understood" textFill="WHITE">
                                 <font>
                                    <Font name="Rockwell" size="18.0" />
                                 </font>
                              </Button>

                           </children>
                        </VBox>

                     </children>
                  </AnchorPane>

              </content>
            </ScrollPane>

         </children>
      </AnchorPane>

   </children>
</AnchorPane>
